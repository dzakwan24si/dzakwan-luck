<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageView
            android:id="@+id/iv_profile"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_social_outline"
            android:src="@drawable/my_foto_removebg_preview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/poppins_regular"
            android:text="Good Morning \uD83D\uDC4D"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/iv_profile"
            app:layout_constraintTop_toTopOf="@id/iv_profile" />

        <TextView
            android:id="@+id/tv_username_dashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/poppins_bold"
            android:text="M.Dzakwan Syafiq"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/iv_profile"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting" />

        <ImageView
            android:id="@+id/iv_notif"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_social_outline"
            android:padding="8dp"
            android:src="@android:drawable/ic_popup_reminder"
            app:layout_constraintBottom_toBottomOf="@id/iv_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_profile" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/banner_card"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/primary_blue"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/iv_profile">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <TextView
                    android:layout_width="202dp"
                    android:layout_height="62dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="Explore how you can secure employment swiftly!"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toStartOf="@+id/iv_banner_icon"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_banner_icon"
                    android:layout_width="109dp"
                    android:layout_height="107dp"
                    android:src="@drawable/koper"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.428" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_menu_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Main Menu"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/banner_card" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="2"
            app:layout_constraintTop_toBottomOf="@id/tv_menu_title">

            <Button
                android:id="@+id/btn_calculator"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/poppins_bold"
                android:text="Kalkulator"
                android:textAllCaps="false"
                android:textColor="@color/text_dark"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_today"
                app:iconGravity="textTop"
                app:iconSize="32dp"
                app:iconTint="@color/primary_blue"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btn_job_vacancy"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/poppins_bold"
                android:text="Lowongan"
                android:textAllCaps="false"
                android:textColor="@color/text_dark"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textTop"
                app:iconSize="32dp"
                app:iconTint="@color/primary_blue"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btn_career_tips"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/poppins_bold"
                android:text="Tips Karir"
                android:textAllCaps="false"
                android:textColor="@color/text_dark"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconGravity="textTop"
                app:iconSize="32dp"
                app:iconTint="@color/primary_blue"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/poppins_bold"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@color/danger_red"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconGravity="textTop"
                app:iconSize="32dp"
                app:iconTint="@color/danger_red"
                app:strokeColor="@color/danger_red"
                app:strokeWidth="1dp" />

        </GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>